PORT=5175
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/fashionZone?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Gmail SMTP — create an App Password at https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM=FashionZone <noreply@fashionzone.com>

# URL of the frontend (used for CORS)
CLIENT_URL=http://localhost:3001

# Additional production origins, comma-separated (set this in Vercel dashboard)
# ALLOWED_ORIGINS=https://fz-frontend.vercel.app,https://yourdomain.com

NODE_ENV=development
